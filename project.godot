; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="NewElaris"
run/main_scene="uid://2gqxwvmlilq6"
config/features=PackedStringArray("4.5", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

EventBus="*res://autoload/event_bus.gd"
GameManager="*res://autoload/game_manager.gd"
ItemDatabase="*res://autoload/item_database.gd"
CombatManager="*res://autoload/combat_manager.gd"
InventoryManager="*res://autoload/inventory_manager.gd"
SaveManager="*res://autoload/save_manager.gd"
ClassDatabase="*res://autoload/class_database.gd"
RaceDatabase="*res://autoload/race_database.gd"
SkillDatabase="*res://autoload/skill_database.gd"
SpellDatabase="*res://autoload/spell_database.gd"
RecipeDatabase="*res://autoload/recipe_database.gd"
LootManager="*res://autoload/loot_manager.gd"
StatusEffectManager="*res://autoload/status_effect_manager.gd"
SpellManager="*res://autoload/spell_manager.gd"
CraftingManager="*res://autoload/crafting_manager.gd"
DialogueManager="*res://autoload/dialogue_manager.gd"
QuestManager="*res://autoload/quest_manager.gd"
FactionManager="*res://autoload/faction_manager.gd"
WorldEventManager="*res://autoload/world_event_manager.gd"
ZoneManager="*res://autoload/zone_manager.gd"
CompanionManager="*res://autoload/companion_manager.gd"
UIManager="*res://autoload/ui_manager.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080

[editor]

version_control/autoload_on_startup=true
